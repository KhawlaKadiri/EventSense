pipeline {
    agent any

    stages {

        stage('Kill old app') {
            steps {
                sh '''
                PID=$(lsof -t -i:8091) && kill -9 $PID || echo "No process running on port 8091"
                '''
            }
        }

        stage('Build app') {
            steps {
                sh 'mvn clean install'
            }
        }

        stage('Run app') {
            steps {
                sh 'nohup mvn spring-boot:run &'
            }
        }
    }
}